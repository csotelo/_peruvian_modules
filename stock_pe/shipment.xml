<?xml version="1.0"?>
<tryton>
  <data>
    <!-- View: Shipment Sequences -->
    <record model="ir.ui.view" id="shipment_out_sequence_view_tree">
      <field name="model">stock.shipment.out.sequence</field>
      <field name="type">tree</field>
      <field name="name">shipment_out_sequence_tree</field>
    </record>
    <record model="ir.ui.view" id="shipment_out_sequence_view_form">
      <field name="model">stock.shipment.out.sequence</field>
      <field name="type">form</field>
      <field name="name">shipment_out_sequence_form</field>
    </record>
    <!-- Actions: Shipment Sequences -->
    <record model="ir.action.act_window" id="act_shipment_out_sequence">
      <field name="name">Secuencias de Guías de remisión</field>
      <field name="res_model">stock.shipment.out.sequence</field>
    </record>
    <record model="ir.action.act_window.view" id="act_shipment_out_sequence_tree_view">
      <field name="sequence" eval="20"/>
      <field name="view" ref="shipment_out_sequence_view_tree"/>
      <field name="act_window" ref="act_shipment_out_sequence"/>
    </record>
    <record model="ir.action.act_window.view" id="act_shipment_out_sequence_form_view">
      <field name="sequence" eval="20"/>
      <field name="view" ref="shipment_out_sequence_view_form"/>
      <field name="act_window" ref="act_shipment_out_sequence"/>
    </record>
    <!-- Menu: Shipment Sequences -->
    <menuitem name="Secuencias de Guías de remisión" parent="stock.menu_stock" id="menu_conf_shipment_out_sequence" action="act_shipment_out_sequence"/>

    <record model="ir.ui.view" id="shipment_out_view_form">
      <field name="model">stock.shipment.out</field>
      <field name="inherit" ref="stock.shipment_out_view_form"/>
      <field name="name">shipment_out_form</field>
    </record>

    <record model="ir.ui.view" id="shipment_out_view_tree">
      <field name="model">stock.shipment.out</field>
      <field name="inherit" ref="stock.shipment_out_view_tree"/>
      <field name="name">shipment_out_tree</field>
    </record>

    <!--Cron-->

    <record model="res.user" id="user_resend_shipments">
      <field name="login">user_cron_resend_shipments</field>
      <field name="name">Cron Resend Shipments</field>
      <field name="signature"></field>
      <field name="active" eval="False"/>
    </record>
    <record model="res.user-res.group" id="user_resend_shipments_group_stock">
      <field name="user" ref="user_resend_shipments"/>
      <field name="group" ref="stock.group_stock"/>
    </record>

    <record model="ir.cron" id="cron_resend_shipments">
      <field name="name">Reenviar guías de remisión a la SUNAT</field>
      <field name="request_user" ref="res.user_admin"/>
      <field name="user" ref="user_resend_shipments"/>
      <field name="active" eval="True"/>
      <field name="interval_number" eval="1"/>
      <field name="interval_type">days</field>
      <field name="number_calls" eval="-1"/>
      <field name="repeat_missed" eval="False"/>
      <field name="model">stock.shipment.out</field>
      <field name="function">import_cron_resend_shipment</field>
    </record>

    <!-- Report: Shipment -->
    <record model="ir.action.report" id="stock.report_shipment_out_picking_list">
        <field name="active" eval="False"/>
    </record>

    <record model="ir.action.report" id="report_shipment_out_picking_list">
        <field name="name">Guía de remisión</field>
        <field name="model">stock.shipment.out</field>
        <field name="report_name">stock.shipment.out.picking_list</field>
        <field name="report">stock_pe/reports/picking_list.odt</field>
    </record>

    <record model="ir.action.keyword" id="report_shipment_out_picking_list_keyword">
        <field name="keyword">form_print</field>
        <field name="model">stock.shipment.out,-1</field>
        <field name="action" ref="report_shipment_out_picking_list"/>
    </record>

  </data>
</tryton>
