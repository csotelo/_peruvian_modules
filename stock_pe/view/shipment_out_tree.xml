<?xml version="1.0"?>
<data>
    <xpath expr="/tree/field[@name='state']" position="after">
        <field name="sunat_generated_status" readonly="1"/>
        <field name="sunat_date_generated" widget="date" readonly="1"/>
        <field 
            name="sunat_date_generated" widget="time" readonly="1"
            string="Hora de generación electrónica"/>
        <field name="sunat_sent_status" readonly="1"/>
        <field name="sunat_date_sent" widget="date" readonly="1"/>
        <field
            name="sunat_date_sent" widget="time" readonly="1"
            string="Hora de envío SUNAT"/>
        <field name="sunat_response_message" readonly="1"/>
        <field name="sunat_sent_observation" readonly="1"/>
    </xpath>
</data>
