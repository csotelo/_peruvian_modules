<?xml version="1.0"?>
<tryton>
    <data>
        <!-- Menues -->
        <!-- Menu: Invoicing -->
        <menuitem name="Facturación" parent="account.menu_account_configuration" id="menu_conf_invoicing" sequence="10" />

        <!-- Invoice Sequences -->

        <!-- View: Invoice Sequences -->
        <record model="ir.ui.view" id="invoice_sequence_view_tree">
            <field name="model">account.invoice.sequence</field>
            <field name="type">tree</field>
            <field name="name">invoice_sequence_tree</field>
        </record>
        <record model="ir.ui.view" id="invoice_sequence_view_form">
            <field name="model">account.invoice.sequence</field>
            <field name="type">form</field>
            <field name="name">invoice_sequence_form</field>
        </record>
        <!-- account.fiscalyear -->
        <record model="ir.ui.view" id="fiscalyear_view_form">
            <field name="model">account.fiscalyear</field>
            <field name="inherit" ref="account.fiscalyear_view_form"/>
            <field name="name">fiscalyear_form</field>
        </record>
        <!-- pay.invoice.start -->
        <record model="ir.ui.view" id="pay_invoice_start_form">
            <field name="model">account.invoice.pay.start</field>
            <field name="inherit" ref="account_invoice.pay_start_view_form"/>
            <field name="name">pay_invoice_start_form</field>
        </record>
        <!-- account.move.line -->
        <record model="ir.ui.view" id="account_move_line_tree">
            <field name="model">account.move.line</field>
            <field name="inherit" ref="account.move_line_view_tree"/>
            <field name="name">account_move_line_tree</field>
        </record>
        <record model="ir.ui.view" id="account_move_line_form">
            <field name="model">account.move.line</field>
            <field name="inherit" ref="account.move_line_view_form"/>
            <field name="name">account_move_line_form</field>
        </record>
        <!-- operation number in list payment -->
        <record model="ir.ui.view" id="move_line_operation_payment">
            <field name="model">account.move.line</field>
            <field name="inherit" ref="account_invoice.move_line_view_list_payment"/>
            <field name="name">move_line_operation_payment</field>
        </record>

        <!-- Actions: Invoice Sequences -->
        <record model="ir.action.act_window" id="act_invoice_sequence">
            <field name="name">Secuencias de facturación</field>
            <field name="res_model">account.invoice.sequence</field>
        </record>
        <record model="ir.action.act_window.view" id="act_invoice_sequence_tree_view">
            <field name="sequence" eval="20"/>
            <field name="view" ref="invoice_sequence_view_tree"/>
            <field name="act_window" ref="act_invoice_sequence"/>
        </record>
        <record model="ir.action.act_window.view" id="act_invoice_sequence_form_view">
            <field name="sequence" eval="20"/>
            <field name="view" ref="invoice_sequence_view_form"/>
            <field name="act_window" ref="act_invoice_sequence"/>
        </record>

        <!-- Menu: Invoice Sequences -->
        <menuitem name="Secuencias de facturación" parent="menu_conf_invoicing" id="menu_conf_invoice_sequence" action="act_invoice_sequence" />

        <!-- View: Invoice -->
        <record model="ir.ui.view" id="invoice_view_form">
            <field name="model">account.invoice</field>
            <field name="inherit" ref="account_invoice.invoice_view_form"/>
            <field name="name">invoice_form</field>
        </record>
        <record model="ir.ui.view" id="invoice_view_tree">
            <field name="model">account.invoice</field>
            <field name="inherit" ref="account_invoice.invoice_view_tree"/>
            <field name="name">invoice_tree</field>
        </record>

        <!-- View: Invoice Line -->
        <record model="ir.ui.view" id="invoice_line_view_form">
            <field name="model">account.invoice.line</field>
            <field name="inherit" ref="account_invoice.invoice_line_view_form"/>
            <field name="name">invoice_line_form</field>
        </record>
        <record model="ir.ui.view" id="invoice_line_view_tree_sequence">
            <field name="model">account.invoice.line</field>
            <field name="inherit" ref="account_invoice.invoice_line_view_tree_sequence"/>
            <field name="name">invoice_line_tree_sequence</field>
        </record>

        <!-- Report: Invoice -->

-        <record model="ir.action.report" id="account_invoice.report_invoice">
-            <field name="active" eval="False"/>
-        </record>

        <record model="ir.action.report" id="report_invoice">
            <field name="name">Factura General</field>
            <field name="report_name">account.invoice</field>
            <field name="model">account.invoice</field>
            <field name="report">account_invoice_pe/reports/invoice.odt</field>
        </record>

        <record model="ir.action.keyword" id="report_invoice_keyword">
            <field name="keyword">form_print</field>
            <field name="model">account.invoice,-1</field>
            <field name="action" ref="report_invoice"/>
        </record>

        <record model="ir.ui.view" id="credit_start_view_form">
            <field name="model">account.invoice.credit.start</field>
            <field name="inherit" ref="account_invoice.credit_start_view_form"/>
            <field name="name">credit_start_form</field>
        </record>

        <!--Cron-->

        <record model="res.user" id="user_resend_invoices">
            <field name="login">user_cron_resend_invoices</field>
            <field name="name">Cron Resend Invoices</field>
            <field name="signature"></field>
            <field name="active" eval="False"/>
        </record>
        <record model="res.user-res.group" id="user_resend_invoices_group_stock">
            <field name="user" ref="user_resend_invoices"/>
            <field name="group" ref="account.group_account"/>
        </record>

        <record model="ir.cron" id="cron_resend_invoices">
            <field name="name">Reenviar facturas a la SUNAT</field>
            <field name="request_user" ref="res.user_admin"/>
            <field name="user" ref="user_resend_invoices"/>
            <field name="active" eval="True"/>
            <field name="interval_number" eval="1"/>
            <field name="interval_type">days</field>
            <field name="number_calls" eval="-1"/>
            <field name="repeat_missed" eval="False"/>
            <field name="model">account.invoice</field>
            <field name="function">import_cron_resend_einvoice</field>
        </record>

        <!--Debit Note. Views and Wizards-->
        <record model="ir.ui.view" id="debit_start_view_form">
            <field name="model">account.invoice.debit.start</field>
            <field name="type">form</field>
            <field name="name">debit_start_form</field>
        </record>

        <record model="ir.action.wizard" id="debit">
            <field name="name">Debit</field>
            <field name="wiz_name">account.invoice.debit</field>
            <field name="model">account.invoice</field>
        </record>
        <record model="ir.action.keyword" id="debit_keyword">
            <field name="keyword">form_action</field>
            <field name="model">account.invoice,-1</field>
            <field name="action" ref="debit"/>
        </record>

        <!--Voided Document. Views and Wizards-->
        <record model="ir.ui.view" id="voided_start_view_form">
            <field name="model">account.invoice.voided.start</field>
            <field name="type">form</field>
            <field name="name">void_start_form</field>
        </record>

        <record model="ir.action.wizard" id="void_wizard">
            <field name="name">Dar de Baja</field>
            <field name="wiz_name">account.invoice.voided</field>
            <field name="model">account.invoice</field>
        </record>

        <record model="ir.action.keyword" id="void_keyword">
            <field name="keyword">form_action</field>
            <field name="model">account.invoice,-1</field>
            <field name="action" ref="void_wizard"/>
        </record>

        <!--Canceled Document. Views and Wizards-->
        <record model="ir.ui.view" id="cancel_start_view_form">
            <field name="model">account.invoice.canceled.start</field>
            <field name="type">form</field>
            <field name="name">cancel_start_form</field>
        </record>

        <record model="ir.action.wizard" id="cancel_wizard">
            <field name="name">Anular</field>
            <field name="wiz_name">account.invoice.canceled</field>
            <field name="model">account.invoice</field>
        </record>

        <record model="ir.action.keyword" id="cancel_keyword">
            <field name="keyword">form_action</field>
            <field name="model">account.invoice,-1</field>
            <field name="action" ref="cancel_wizard"/>
        </record>

        <!--Added tabs to tree view-->
        <record model="ir.action.act_window.domain" id="act_invoice_out_domain_paid">
            <field name="name">Pagada</field>
            <field name="sequence" eval="40"/>
            <field name="domain" eval="[('state', '=', 'paid')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="account_invoice.act_invoice_out_form"/>
        </record>

        <record model="ir.action.act_window.domain" id="act_invoice_out_domain_cancel">
            <field name="name">Anulada</field>
            <field name="sequence" eval="50"/>
            <field name="domain" eval="[('state', '=', 'anulado')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="account_invoice.act_invoice_out_form"/>
        </record>

        <record model="ir.action.act_window.domain" id="act_invoice_out_domain_voided">
            <field name="name">En Baja</field>
            <field name="sequence" eval="40"/>
            <field name="domain" eval="[('state', '=', 'voided')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="account_invoice.act_invoice_out_form"/>
        </record>

        <record model="ir.action.act_window.domain" id="act_invoice_in_domain_paid">
            <field name="name">Pagada</field>
            <field name="sequence" eval="40"/>
            <field name="domain" eval="[('state', '=', 'paid')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="account_invoice.act_invoice_in_form"/>
        </record>

        <record model="ir.action.act_window.domain" id="act_invoice_in_domain_cancel">
            <field name="name">Anulado</field>
            <field name="sequence" eval="50"/>
            <field name="domain" eval="[('state', '=', 'anulado')]" pyson="1"/>
            <field name="count" eval="True"/>
            <field name="act_window" ref="account_invoice.act_invoice_in_form"/>
        </record>
    </data>
</tryton>
